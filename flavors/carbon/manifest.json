{
  "name": "carbon",
  "description": "Swap the shadcn/ui frontend for IBM Carbon (@carbon/react): UI Shell layout, Carbon components on every page, g10/g90 theme zones, and Carbon tokens exposed to Tailwind.",
  "conflicts": ["no-database", "backend-only", "oauth-proxy"],
  "requires": [],
  "delete": [
    "frontend/src/components/ui/**",
    "frontend/src/components/mode-toggle.tsx",
    "frontend/src/lib/utils.ts",
    "frontend/src/styles/themes/**"
  ],
  "overlay": "overlay",
  "edits": [
    {
      "file": "frontend/src/main.tsx",
      "find": "import \"./styles/index.css\";\n",
      "replace": "import \"./styles/carbon.scss\";\nimport \"./styles/index.css\";\n"
    }
  ],
  "packageJson": {
    "@cen/frontend": {
      "add": {
        "@carbon/icons-react": "^11.83.0",
        "@carbon/react": "^1.111.0",
        "sass-embedded": "^1.100.0"
      },
      "remove": [
        "@radix-ui/react-avatar",
        "@radix-ui/react-dialog",
        "@radix-ui/react-dropdown-menu",
        "@radix-ui/react-label",
        "@radix-ui/react-separator",
        "@radix-ui/react-slot",
        "class-variance-authority",
        "clsx",
        "lucide-react",
        "tailwind-merge"
      ]
    }
  },
  "verify": ["pnpm check", "pnpm test"]
}
