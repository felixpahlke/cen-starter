{
  "name": "cen-starter",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "cen": {
    "templateVersion": "0.3.0",
    "flavors": [],
    "finalized": false
  },
  "scripts": {
    "dev": "docker compose up -d --wait && pnpm db:migrate && pnpm --recursive --parallel dev",
    "flavor": "tsx scripts/flavor.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "typecheck": "tsc --noEmit",
    "check": "pnpm --recursive --include-workspace-root --if-present typecheck && biome check .",
    "test": "pnpm --recursive --if-present run test",
    "fix": "biome check --write .",
    "build": "pnpm --recursive build",
    "verify": "pnpm check && pnpm test && pnpm build",
    "verify:flavors": "tsx scripts/verify-flavors.ts",
    "db:generate": "pnpm --filter @cen/backend db:generate",
    "db:migrate": "pnpm --filter @cen/backend db:migrate",
    "db:studio": "pnpm --filter @cen/backend db:studio",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "lefthook": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  }
}
