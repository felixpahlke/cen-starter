{
  "name": "cen-starter",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "cen": {
    "templateVersion": "0.3.0",
    "flavors": [],
    "bootstrapped": false,
    "finalized": false
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "flavor": "tsx .template/scripts/flavor.ts",
    "bootstrap": "tsx .template/scripts/bootstrap.ts",
    "typecheck": "tsc -p .template --noEmit",
    "check": "pnpm --recursive --include-workspace-root --if-present typecheck && biome check .",
    "test": "pnpm test:container-engine && pnpm --recursive --if-present run test",
    "test:container-engine": "node --test scripts/container-engine.test.mjs",
    "fix": "biome check --write .",
    "build": "pnpm --recursive build",
    "verify": "pnpm check && pnpm test && pnpm build",
    "verify:flavors": "tsx .template/scripts/verify-flavors.ts",
    "db:generate": "node .template/scripts/guard-setup.mjs && pnpm --filter @cen/backend db:generate",
    "db:migrate": "pnpm --filter @cen/backend db:migrate",
    "db:seed": "pnpm --filter @cen/backend db:seed",
    "db:studio": "pnpm --filter @cen/backend db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  }
}
